{
  "name": "wfh-attendance-backend",
  "version": "1.0.0",
  "description": "WFH Attendance Web Application - Backend API",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/api",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typeorm": "ts-node --files ./node_modules/typeorm/cli.js",
    "migration:create": "ts-node ./bin/generate-migration.ts",
    "migration:run": "npm run typeorm migration:run -- -d ./bin/typeorm.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d ./bin/typeorm.ts",
    "seed:create": "ts-node ./bin/generate-seeder.ts --path=src/database/seeders",
    "seed:run": "ts-node --files ./node_modules/@jorgebodega/typeorm-seeding/dist/cli.js seed -d ./bin/typeorm.ts ./src/database/seeders/$npm_config_name.*.ts",
    "seed:run:all": "ts-node --files ./node_modules/@jorgebodega/typeorm-seeding/dist/cli.js seed -d ./bin/typeorm.ts ./src/database/seeders/*.ts"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@jorgebodega/typeorm-seeding": "^6.0.1",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.2.0",
    "bcrypt": "^5.1.1",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "mysql2": "^3.7.0",
    "reflect-metadata": "^0.2.1",
    "redis": "^4.7.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.19"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
